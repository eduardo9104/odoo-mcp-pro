# Multi-tenant deployment environment variables
# Copy to .env and fill in your values

# Postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password

# API key encryption (Fernet)
# Generate with: python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
API_KEY_ENCRYPTION_KEY=

# Admin panel
ADMIN_SESSION_SECRET=change-me-to-a-random-string-32-chars-or-more
ADMIN_OAUTH_CLIENT_ID=your-zitadel-oidc-app-client-id
ADMIN_BASE_URL=https://mcp.example.com
ADMIN_BOOTSTRAP_SUB=your-zitadel-subject-id
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# OAuth (Zitadel)
OAUTH_ISSUER_URL=https://your-instance.zitadel.cloud
ZITADEL_INTROSPECTION_URL=https://your-instance.zitadel.cloud/oauth/v2/introspect
ZITADEL_CLIENT_ID=your-api-app-client-id
ZITADEL_CLIENT_SECRET=your-api-app-client-secret
OAUTH_RESOURCE_SERVER_URL=https://mcp.example.com/mcp

# MCP OIDC client ID (returned by /register DCR endpoint to Claude.ai)
MCP_OIDC_CLIENT_ID=your-zitadel-oidc-app-client-id

# Domain for Caddy
DOMAIN=mcp.example.com
ZITADEL_HOST=your-instance.zitadel.cloud
