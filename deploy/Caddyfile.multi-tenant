(mcp_upstream) {
    reverse_proxy mcp-blue:8000 mcp-green:8000 {
        lb_policy first
        health_uri /.well-known/oauth-protected-resource
        health_interval 5s
        health_timeout 3s
    }
}

{$DOMAIN:mcp.example.com} {
    # Admin panel
    handle /admin/* {
        import mcp_upstream
    }

    # OAuth well-known endpoints (served by MCP server)
    handle /.well-known/oauth-authorization-server {
        import mcp_upstream
    }
    handle /.well-known/oauth-protected-resource {
        import mcp_upstream
    }
    handle /.well-known/oauth-protected-resource/* {
        import mcp_upstream
    }

    # Proxy OAuth endpoints to Zitadel
    # Claude.ai (web) constructs /authorize and /token relative to server root,
    # ignoring authorization_endpoint/token_endpoint from metadata
    handle /authorize* {
        uri replace /authorize /oauth/v2/authorize
        reverse_proxy {$ZITADEL_HOST:odoo-mcp-pro-x4tprs.us1.zitadel.cloud} {
            header_up Host {upstream_hostport}
        }
    }
    handle /token* {
        uri replace /token /oauth/v2/token
        reverse_proxy {$ZITADEL_HOST:odoo-mcp-pro-x4tprs.us1.zitadel.cloud} {
            header_up Host {upstream_hostport}
        }
    }
    handle /oauth/v2/* {
        reverse_proxy {$ZITADEL_HOST:odoo-mcp-pro-x4tprs.us1.zitadel.cloud} {
            header_up Host {upstream_hostport}
        }
    }

    # DCR endpoint (RFC 7591 — Claude.ai auto-registers here)
    handle /register {
        import mcp_upstream
    }

    # MCP endpoint
    handle /mcp {
        import mcp_upstream
    }
    handle /mcp/* {
        import mcp_upstream
    }

    respond 404
}
